---
import Base from "../../layouts/Base.astro";
import PdfCard from "../../components/PdfCard.astro";
import { getSnapshot } from "../../lib/sheets";
import { chapterSlug } from "../../lib/slug";
import { formatPretty } from "../../lib/today";
import { pdfsForChapter, groupByCategory } from "../../lib/pdf";
import type { Chapter, PdfRecord } from "../../types/sheet";

export async function getStaticPaths() {
  const snap = getSnapshot("syllabus");
  const chapters = snap.rows.filter((r) => r["Paper"]) as unknown as Chapter[];

  return chapters.map((ch) => ({
    params: { chapter: chapterSlug(ch.Paper, ch["Ch#"], ch["Chapter / Unit"]) },
    props: { chapter: ch },
  }));
}

interface Props {
  chapter: Chapter;
}
const { chapter } = Astro.props;

const paperKey = chapter.Paper.toLowerCase();
const paperLabel: Record<string, string> = {
  P4:  "Paper 4 · Cost & Management Accounting",
  P5:  "Paper 5 · Auditing & Ethics",
  P6A: "Paper 6A · Financial Management",
  P6B: "Paper 6B · Strategic Management",
};
const prioLabel = chapter.Priority.replace(/^[^\w]+/, "").trim();
const prioKey = chapter.Priority.includes("Must") ? "must" : chapter.Priority.includes("Important") ? "imp" : "low";
const weightPct = Math.round(chapter.Weight * 100);

// Pull all PDFs that apply to this chapter (paper-wide + chapter-specific + Paper-6 RTPs/QPs for P6A/P6B)
const allPdfs = getSnapshot("pdfs").rows.filter((r) => r["Path"]) as unknown as PdfRecord[];
const myPdfs = pdfsForChapter(chapter, allPdfs);
const pdfGroups = groupByCategory(myPdfs);
---
<Base
  eyebrow={paperLabel[chapter.Paper] ?? chapter.Paper}
  title={chapter["Chapter / Unit"]}
  description={`Chapter ${chapter["Ch#"]} · ${chapter["Total hrs"]} planned hours · ~${weightPct}% paper weightage.`}
>
  <div class="head-chips">
    <span class={`chip chip--${paperKey}`}>{chapter.Paper} · Ch {chapter["Ch#"]}</span>
    <span class={`chip chip--${prioKey}`}>{prioLabel}</span>
    <span class="chip" data-field="done" data-ch={chapter["#"]} hidden={!chapter["Done?"]} style="background: var(--p6a-soft); color: var(--p6a);">✓ done</span>
  </div>

  <section class="meta-grid">
    <div class="meta-card"><dt>Theory</dt><dd>{chapter.Theory}h</dd></div>
    <div class="meta-card"><dt>Practice</dt><dd>{chapter.Practice}h</dd></div>
    <div class="meta-card"><dt>Lecture</dt><dd>{chapter.Lecture}h</dd></div>
    <div class="meta-card"><dt>Total</dt><dd>{chapter["Total hrs"]}h</dd></div>
    <div class="meta-card"><dt>Weight</dt><dd>{weightPct}%</dd></div>
    <div class="meta-card"><dt>ICAI section</dt><dd>{chapter["ICAI Sec"]} <span class="meta-band">({chapter.Band})</span></dd></div>
    {chapter.Start && <div class="meta-card"><dt>Starts</dt><dd>{formatPretty(chapter.Start)}</dd></div>}
    {chapter.End && <div class="meta-card"><dt>Ends</dt><dd>{formatPretty(chapter.End)}</dd></div>}
  </section>

  <section class="pdfs">
    <header class="pdfs__head">
      <h2>Reading material</h2>
      <span class="pdfs__count">{myPdfs.length} PDF{myPdfs.length === 1 ? "" : "s"}</span>
    </header>

    {pdfGroups.length === 0 ? (
      <p class="pdfs__empty">
        No PDFs linked to this chapter yet. Add a row to the <code>11 · PDFs</code> tab
        in your Google Sheet (Paper <code>{chapter.Paper}</code>, Ch# <code>{chapter["Ch#"]}</code>),
        then drop the file into <code>public/pdfs/</code>. See <code>MAINTENANCE.md</code> §2.
      </p>
    ) : (
      pdfGroups.map((g) => (
        <div class="pdfs__group">
          <h3 class="pdfs__group-title">{g.category}</h3>
          <div class="pdfs__grid">
            {g.items.map((p) => (
              <PdfCard
                title={p.Title}
                path={p.Path}
                category={g.category}
                paper={p.Paper}
                chapter={p["Ch#"]}
                pages={p.Pages}
                notes={p.Notes}
              />
            ))}
          </div>
        </div>
      ))
    )}
  </section>

  <section class="notes" data-field="notes" data-ch={chapter["#"]} hidden={!chapter.Notes}>
    <h2>Notes</h2>
    <p data-field-value>{chapter.Notes ?? ""}</p>
  </section>

  <p class="backlink">
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/syllabus`}>← All chapters</a>
  </p>
</Base>

<style>
  .head-chips {
    display: flex;
    gap: var(--s-2);
    margin: calc(-1 * var(--s-4)) 0 var(--s-5);
    flex-wrap: wrap;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--s-3);
    margin-bottom: var(--s-7);
  }
  .meta-card {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    padding: var(--s-3) var(--s-4);
  }
  .meta-card dt {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    margin-bottom: 4px;
  }
  .meta-card dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
  }
  .meta-band {
    font-size: 12px;
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-weight: 400;
  }

  .pdfs__head {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    margin-bottom: var(--s-4);
  }
  .pdfs__head h2 {
    margin: 0;
    font-size: var(--t-h4);
    font-weight: 500;
  }
  .pdfs__count {
    font-family: var(--font-mono);
    font-size: var(--t-meta);
    color: var(--ink-mute);
    margin-left: auto;
  }
  .pdfs__empty {
    color: var(--ink-mute);
    padding: var(--s-5);
    background: var(--bg-card);
    border: 1px dashed var(--rule-2);
    border-radius: var(--radius);
  }
  .pdfs__group {
    margin-bottom: var(--s-5);
  }
  .pdfs__group-title {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
    margin: 0 0 var(--s-2);
  }
  .pdfs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--s-3);
  }
  code {
    background: var(--cream-2);
    padding: 1px 6px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .notes {
    margin-top: var(--s-7);
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: var(--s-5);
  }
  .notes h2 {
    font-size: var(--t-h4);
    font-weight: 500;
    margin: 0 0 var(--s-3);
  }

  .backlink {
    margin-top: var(--s-7);
    font-size: var(--t-meta);
  }
</style>
