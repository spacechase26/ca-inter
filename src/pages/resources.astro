---
import Base from "../layouts/Base.astro";
import { getSnapshot } from "../lib/sheets";
import type { Resource } from "../types/sheet";

const snap = getSnapshot("resources");
const resources = snap.rows.filter((r) => r["Name"]) as unknown as Resource[];

// Group by category, preserving first-seen order
const groups = new Map<string, Resource[]>();
for (const r of resources) {
  const key = r.Category || "Other";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(r);
}
---
<Base
  eyebrow="Resources & references"
  title="Where to read, watch, and check"
  description="Official ICAI portals plus curated free YouTube channels."
>
  {[...groups.entries()].map(([category, items]) => (
    <section class="cat">
      <h2 class="cat__title">{category}</h2>
      <ul class="rlist">
        {items.map((r) => (
          <li class="r">
            {r.Link ? (
              <a class="r__name" href={r.Link} target="_blank" rel="noopener noreferrer">{r.Name} ↗</a>
            ) : (
              <span class="r__name">{r.Name}</span>
            )}
            {r.Notes && <p class="r__notes">{r.Notes}</p>}
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .cat {
    margin-bottom: var(--s-7);
  }
  .cat__title {
    font-size: var(--t-h4);
    font-weight: 500;
    margin: 0 0 var(--s-3);
    padding-bottom: var(--s-2);
    border-bottom: 1px solid var(--rule);
  }
  .rlist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .r {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: var(--s-3) var(--s-5);
  }
  .r__name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
  }
  a.r__name { border-bottom: 1px solid var(--rule-2); padding-bottom: 1px; }
  a.r__name:hover { border-color: var(--ink); }
  .r__notes {
    margin: 4px 0 0;
    font-size: 14px;
    color: var(--ink-mute);
  }
</style>
