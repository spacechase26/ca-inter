---
import Base from "../../layouts/Base.astro";
import PdfViewer from "../../components/PdfViewer.astro";
import { getSnapshot } from "../../lib/sheets";
import { pdfSlug } from "../../lib/pdf";
import type { PdfRecord } from "../../types/sheet";

export async function getStaticPaths() {
  const snap = getSnapshot("pdfs");
  const rows = snap.rows.filter((r) => r["Path"]) as unknown as PdfRecord[];

  // When the same Path appears in multiple rows (e.g. one paper-wide row + one
  // chapter-specific row), prefer the most general row for the viewer page —
  // the eyebrow shouldn't claim "Ch 3" for a PDF that's actually paper-wide.
  // Generality: blank Paper + blank Ch# (cross-paper) > blank Ch# (paper-wide)
  // > specific Ch#. Stable-sort, then take first per slug.
  const generality = (r: PdfRecord) => {
    const hasPaper = (r.Paper ?? "").trim() !== "";
    const hasCh = String(r["Ch#"] ?? "").trim() !== "";
    return (hasPaper ? 1 : 0) + (hasCh ? 1 : 0); // 0 = most general
  };
  const sorted = [...rows].sort((a, b) => generality(a) - generality(b));

  const seen = new Set<string>();
  return sorted
    .filter((p) => {
      const s = pdfSlug(p.Path);
      if (seen.has(s)) return false;
      seen.add(s);
      return true;
    })
    .map((p) => ({
      params: { slug: pdfSlug(p.Path) },
      props: { record: p },
    }));
}

interface Props {
  record: PdfRecord;
}
const { record } = Astro.props;
const eyebrow = [record.Category, record.Paper, record["Ch#"] ? `Ch ${record["Ch#"]}` : null]
  .filter(Boolean)
  .join(" · ");
---
<Base eyebrow={eyebrow} title={record.Title} description={record.Notes ?? undefined}>
  <PdfViewer path={record.Path} label={record.Title} />
  <p class="backlink">
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/library`}>← Library</a>
  </p>
</Base>

<style>
  .backlink {
    margin-top: var(--s-5);
    font-size: var(--t-meta);
  }
</style>
