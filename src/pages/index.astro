---
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CA Inter G2 · Companion</title>
    <style>
      body { font-family: system-ui, -apple-system, sans-serif; max-width: 640px; margin: 80px auto; padding: 0 24px; color: #14110D; line-height: 1.55; }
      h1 { font-size: 28px; margin-bottom: 8px; }
      .sub { color: #8A7E6E; font-size: 14px; }
      code { background: #F6EFE2; padding: 2px 6px; border-radius: 4px; font-size: 13px; }
    </style>
  </head>
  <body>
    <h1>CA Inter · Group 2 · Companion site</h1>
    <p class="sub">Scaffold deployed. Base path: <code>{base}</code></p>
    <p>Next phase: data layer.</p>
  </body>
</html>
