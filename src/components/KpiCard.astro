---
interface Props {
  label: string;
  value: string | number;
  suffix?: string;
  hint?: string;
  accent?: "p4" | "p5" | "p6a" | "p6b" | "neutral";
  dataKey?: string;
}

const { label, value, suffix, hint, accent = "neutral", dataKey } = Astro.props;
---
<div class={`kpi kpi--${accent}`} data-kpi={dataKey}>
  <span class="kpi__label">{label}</span>
  <span class="kpi__value">
    {value}
    {suffix && <span class="kpi__suffix">{suffix}</span>}
  </span>
  {hint && <span class="kpi__hint">{hint}</span>}
</div>

<style>
  .kpi {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: var(--s-4) var(--s-5);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 3px solid var(--accent, var(--ink-mute));
    min-height: 110px;
  }
  .kpi--p4 { --accent: var(--p4); }
  .kpi--p5 { --accent: var(--p5); }
  .kpi--p6a { --accent: var(--p6a); }
  .kpi--p6b { --accent: var(--p6b); }
  .kpi--neutral { --accent: var(--ink-2); }

  .kpi__label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-mute);
  }
  .kpi__value {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 500;
    line-height: 1;
    color: var(--ink);
  }
  .kpi__suffix {
    font-size: 18px;
    color: var(--ink-mute);
    margin-left: 4px;
  }
  .kpi__hint {
    font-size: var(--t-meta);
    color: var(--ink-mute);
    margin-top: auto;
  }
</style>
