---
import "../styles/base.css";
import RefreshButton from "../components/RefreshButton.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F6EFE2" />
    <meta name="description" content={description ?? "CA Inter Group 2 study companion"} />
    <title>{title} · CA Inter G2</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Warm the jsdelivr + Apps Script TLS connections on every page so the
        first PDF / sync call doesn't pay a 30 s handshake cost. Apps Script
        web apps 302 to script.googleusercontent.com for the response body,
        so we preconnect both ends. */}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://script.google.com" crossorigin />
    <link rel="preconnect" href="https://script.googleusercontent.com" crossorigin />
    {/* Only the weights actually used: Fraunces 500 (h1/h2 only), Inter 400/500/700,
        JetBrains Mono 400/500. Trimmed Fraunces 400/600 and Inter 600 (unused). */}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500&family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar__inner">
        <a class="brand" href={base}>
          <span class="brand__mark">📚</span>
          <span class="brand__text">CA Inter · G2</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href={`${base}/today`}>Today</a>
          <a href={`${base}/daily`}>Daily</a>
          <a href={`${base}/syllabus`}>Syllabus</a>
          <a href={`${base}/library`}>Library</a>
          <a href={`${base}/mocks`}>Mocks</a>
          <a href={`${base}/phases`}>Phases</a>
          <a href={`${base}/notes`}>Notes</a>
          <a href={`${base}/resources`}>Resources</a>
          <a href={`${base}/wellness`}>Wellness</a>
          <RefreshButton />
        </nav>
      </div>
    </header>
    <main>
      <div class="container page">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h1 class="page__title">{title}</h1>
        {description && <p class="page__desc">{description}</p>}
        <slot />
      </div>
    </main>
    <footer class="footer">
      <div class="container footer__inner">
        <blockquote class="quote" data-role="quote">
          <span class="quote__text" data-role="quote-text">Discipline is the bridge between goals and accomplishment.</span>
          <cite class="quote__author" data-role="quote-author">— Jim Rohn</cite>
        </blockquote>
        <div class="footer__meta">
          <span class="meta">CA Inter · Group 2 · Jan 2027 · Harendra K.</span>
          <span class="meta">Data lives in your Google Sheet · synced live</span>
        </div>
      </div>
    </footer>

    <script>
      // Rotate quote by day-of-year so it changes once a day, deterministically.
      const QUOTES = [
        ["Discipline is the bridge between goals and accomplishment.", "Jim Rohn"],
        ["Success is the sum of small efforts repeated day in and day out.", "Robert Collier"],
        ["It always seems impossible until it's done.", "Nelson Mandela"],
        ["He who has a why to live can bear almost any how.", "Friedrich Nietzsche"],
        ["The expert in anything was once a beginner.", "Helen Hayes"],
        ["Compound interest is the eighth wonder of the world.", "Albert Einstein"],
        ["You don't have to be great to start, but you have to start to be great.", "Zig Ziglar"],
        ["Hard work beats talent when talent doesn't work hard.", "Tim Notke"],
        ["The future depends on what you do today.", "Mahatma Gandhi"],
        ["Don't watch the clock; do what it does. Keep going.", "Sam Levenson"],
        ["A river cuts through rock not because of its power, but its persistence.", "James N. Watkins"],
        ["Motivation is what gets you started. Habit is what keeps you going.", "Jim Rohn"],
        ["Quality is not an act, it is a habit.", "Aristotle"],
        ["Excellence is a continuous process and not an accident.", "A. P. J. Abdul Kalam"],
      ];
      const d = new Date();
      const dayOfYear = Math.floor((d.valueOf() - new Date(d.getFullYear(), 0, 0).valueOf()) / 86400000);
      const [text, author] = QUOTES[dayOfYear % QUOTES.length];
      const t = document.querySelector('[data-role="quote-text"]');
      const a = document.querySelector('[data-role="quote-author"]');
      if (t) t.textContent = text;
      if (a) a.textContent = `— ${author}`;
    </script>

    <style>
      .topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(246, 239, 226, 0.92);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--rule);
      }
      .topbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--s-4);
        padding: var(--s-3) var(--gutter);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        text-decoration: none;
        font-family: var(--font-display);
        font-size: 18px;
        font-weight: 500;
        color: var(--ink);
      }
      .brand__mark { font-size: 22px; }
      .nav {
        display: flex;
        gap: var(--s-3);
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .nav a {
        font-size: 14px;
        font-weight: 500;
        color: var(--ink-2);
        text-decoration: none;
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
      }
      .nav a:hover { background: var(--bg-elev); color: var(--ink); }

      .page {
        padding: clamp(24px, 5vw, 56px) 0 64px;
      }
      .page__title {
        font-size: var(--t-h1);
        font-weight: 500;
        margin: 0 0 var(--s-3);
      }
      .page__desc {
        color: var(--ink-2);
        font-size: var(--t-lead);
        max-width: 720px;
        margin: 0 0 var(--s-6);
      }

      .footer {
        margin-top: var(--s-8);
        padding: var(--s-5) 0;
        border-top: 1px solid var(--rule);
      }
      .footer__inner {
        display: flex;
        flex-direction: column;
        gap: var(--s-4);
      }
      .footer__meta {
        display: flex;
        justify-content: space-between;
        gap: var(--s-3);
        flex-wrap: wrap;
      }
      .quote {
        margin: 0;
        padding: var(--s-3) 0;
        text-align: center;
        font-family: var(--font-display);
        color: var(--ink-2);
        max-width: 640px;
        align-self: center;
      }
      .quote__text {
        display: block;
        font-size: 17px;
        line-height: 1.45;
        font-style: italic;
        font-weight: 400;
      }
      .quote__author {
        display: block;
        margin-top: var(--s-2);
        font-family: var(--font-mono);
        font-size: 11px;
        font-style: normal;
        color: var(--ink-mute);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      @media (max-width: 640px) {
        .topbar__inner { flex-direction: column; align-items: flex-start; gap: var(--s-2); }
        .nav { width: 100%; justify-content: flex-start; }
      }
    </style>
  </body>
</html>
